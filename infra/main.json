              }
            },
            "namespaceName": {
              "type": "string",
              "metadata": {
                "description": "Service Bus namespace name"
              }
            },
            "skuName": {
              "type": "string",
              "allowedValues": [
                "Standard",
                "Premium"
              ],
              "metadata": {
                "description": "Service Bus SKU — Standard or Premium required for Topics"
              }
            }
          },
          "variables": {
            "topicDefs": [
              {
                "topicName": "low-stock-events",
                "subscriptionName": "low-stock-handler"
              },
              {
                "topicName": "order-status-changed",
                "subscriptionName": "order-status-handler"
              }
            ]
          },
          "resources": [
            {
              "type": "Microsoft.ServiceBus/namespaces",
              "apiVersion": "2021-11-01",
              "name": "[parameters('namespaceName')]",
              "location": "[parameters('location')]",
              "tags": {
                "environment": "[parameters('environment')]"
              },
              "sku": {
                "name": "[parameters('skuName')]",
                "tier": "[parameters('skuName')]"
              }
            },
            {
              "copy": {
                "name": "sbTopics",
                "count": "[length(variables('topicDefs'))]"
              },
              "type": "Microsoft.ServiceBus/namespaces/topics",
              "apiVersion": "2021-11-01",
              "name": "[format('{0}/{1}', parameters('namespaceName'), variables('topicDefs')[copyIndex()].topicName)]",
              "properties": {
                "enablePartitioning": false,
                "maxSizeInMegabytes": 1024,
                "defaultMessageTimeToLive": "P14D"
              },
              "dependsOn": [
                "[resourceId('Microsoft.ServiceBus/namespaces', parameters('namespaceName'))]"
              ]
            },
            {
              "copy": {
                "name": "sbSubscriptions",
                "count": "[length(variables('topicDefs'))]"
              },
              "type": "Microsoft.ServiceBus/namespaces/topics/subscriptions",
              "apiVersion": "2021-11-01",
              "name": "[format('{0}/{1}/{2}', parameters('namespaceName'), variables('topicDefs')[copyIndex()].topicName, variables('topicDefs')[copyIndex()].subscriptionName)]",
              "properties": {
                "lockDuration": "PT1M",
                "maxDeliveryCount": 10,
                "defaultMessageTimeToLive": "P14D",
                "deadLetteringOnMessageExpiration": true
              },
              "dependsOn": [
                "[resourceId('Microsoft.ServiceBus/namespaces/topics', parameters('namespaceName'), variables('topicDefs')[copyIndex()].topicName)]"
              ]
            }
          ],
          "outputs": {
            "serviceBusNamespaceId": {
              "type": "string",
