            },
            "sqlAdminPassword": {
              "type": "securestring",
              "metadata": {
                "description": "SQL Server administrator password — must arrive via Key Vault reference, never plain text"
              }
            },
            "sqlSkuName": {
              "type": "string",
              "allowedValues": [
                "Basic",
                "S2"
              ],
              "metadata": {
                "description": "SQL Database SKU name  (Basic | S2)"
              }
            },
            "sqlSkuTier": {
              "type": "string",
              "allowedValues": [
                "Basic",
                "Standard"
              ],
              "metadata": {
                "description": "SQL Database SKU tier  (Basic | Standard)"
