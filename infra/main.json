            },
            "containerAppEnvName": {
              "type": "string",
              "metadata": {
                "description": "Container App Environment name"
              }
            },
            "containerAppName": {
              "type": "string",
              "metadata": {
                "description": "Container App name"
              }
            },
            "containerImage": {
              "type": "string",
              "metadata": {
