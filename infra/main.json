{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.44.1.10279",
      "templateHash": "8225393252510553360"
    }
  },
  "parameters": {
    "environment": {
      "type": "string",
      "allowedValues": [
        "dev",
        "prod"
      ],
      "metadata": {
        "description": "Deployment environment — controls all SKU and scaling decisions"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "eastasia",
      "metadata": {
        "description": "Azure region for all resources"
      }
    },
    "sqlAdminLogin": {
      "type": "string",
      "metadata": {
        "description": "SQL Server administrator login"
      }
    },
    "sqlAdminPassword": {
      "type": "securestring",
      "metadata": {
        "description": "SQL administrator password — supplied via Key Vault reference, never plain text"
      }
    },
    "minReplicas": {
      "type": "int",
      "minValue": 0,
      "metadata": {
        "description": "Minimum Container App replicas (0 = scale-to-zero in dev)"
      }
    },
    "sqlSku": {
      "type": "string",
      "allowedValues": [
        "Basic",
        "Standard"
      ],
      "metadata": {
        "description": "SQL Database SKU (Basic → dev 2 GB  |  Standard → prod S2 50 GB)"
      }
    },
    "keyVaultName": {
      "type": "string",
      "metadata": {
        "description": "Name of the pre-existing Key Vault that holds application secrets"
      }
    },
    "containerImage": {
      "type": "string",
      "defaultValue": "mcr.microsoft.com/dotnet/samples:aspnetapp",
      "metadata": {
        "description": "Container image to run in the API Container App"
      }
    }
  },
  "variables": {
    "prefix": "[format('marblecraft-{0}', parameters('environment'))]",
    "sqlSkuMap": {
      "Basic": {
        "skuName": "Basic",
        "skuTier": "Basic",
        "maxSizeBytes": 2147483648
      },
      "Standard": {
        "skuName": "S2",
        "skuTier": "Standard",
        "maxSizeBytes": 53687091200
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName'))]",
      "name": "[guid(resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName')), format('{0}-api', variables('prefix')), 'kv-secrets-user')]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '4633458b-17de-408a-b874-0445c86b69e6')]",
        "principalId": "[reference(resourceId('Microsoft.Resources/deployments', format('{0}-api-deploy', variables('prefix'))), '2025-04-01').outputs.principalId.value]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Resources/deployments', format('{0}-api-deploy', variables('prefix')))]"
      ]
    },
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "[format('{0}-sql-deploy', variables('prefix'))]",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "location": {
            "value": "[parameters('location')]"
          },
          "environment": {
            "value": "[parameters('environment')]"
          },
          "sqlServerName": {
            "value": "[format('{0}-sqlserver', variables('prefix'))]"
          },
          "sqlDatabaseName": {
            "value": "[format('{0}-db', variables('prefix'))]"
          },
          "sqlAdminLogin": {
            "value": "[parameters('sqlAdminLogin')]"
          },
          "sqlAdminPassword": {
            "value": "[parameters('sqlAdminPassword')]"
          },
          "sqlSkuName": {
            "value": "[variables('sqlSkuMap')[parameters('sqlSku')].skuName]"
