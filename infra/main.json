          "containerImage": {
            "value": "[parameters('containerImage')]"
          },
          "cpuCore": "[if(equals(parameters('environment'), 'dev'), createObject('value', '0.5'), createObject('value', '1'))]",
          "memorySize": "[if(equals(parameters('environment'), 'dev'), createObject('value', '1Gi'), createObject('value', '2Gi'))]",
          "minReplicas": {
