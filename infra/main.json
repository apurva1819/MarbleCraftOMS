          "sqlSkuTier": {
            "value": "[variables('sqlSkuMap')[parameters('sqlSku')].skuTier]"
          },
          "sqlMaxSizeBytes": {
            "value": "[variables('sqlSkuMap')[parameters('sqlSku')].maxSizeBytes]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.44.1.10279",
              "templateHash": "12102505694791155365"
            }
          },
          "parameters": {
            "location": {
              "type": "string",
              "metadata": {
                "description": "Azure region for all resources"
              }
            },
            "environment": {
              "type": "string",
              "metadata": {
                "description": "Deployment environment tag (dev | prod)"
              }
