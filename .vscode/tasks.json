{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "kill-port-7001",
      "type": "process",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-Command",
        "Get-NetTCPConnection -LocalPort 7001 -ErrorAction SilentlyContinue | ForEach-Object { Stop-Process -Id $_.OwningProcess -Force -ErrorAction SilentlyContinue }; exit 0"
      ],
      "presentation": { "reveal": "silent", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "build",
      "dependsOn": "kill-port-7001",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/src/MarbleCraftOMS.Api/MarbleCraftOMS.Api.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary",
        "--configuration",
        "Debug"
      ],
      "problemMatcher": "$msCompile"
    }
  ]
}
